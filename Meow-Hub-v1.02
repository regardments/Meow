-- Cache for ESP calculations
local distCache = {}

local function isMob(model)
    return model.Name:sub(1, 1) == "."
end

local function startFly()
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if St.flyBV then St.flyBV:Destroy() end
    St.flyBV = Instance.new("BodyVelocity")
    St.flyBV.Name = "FlyBV"
    St.flyBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    St.flyBV.Velocity = Vector3.zero
    St.flyBV.Parent = hrp
    CollectionService:AddTag(St.flyBV, "AllowedBM")
end

local function stopFly()
    if St.flyBV then
        St.flyBV:Destroy()
        St.flyBV = nil
    end
end

-- Agility spoofer functions
local function saveAgilityValue(playerModel)
    local passiveAgility = playerModel:FindFirstChild("PassiveAgility")
    if passiveAgility and savedAgilityValues[playerModel] == nil then
        savedAgilityValues[playerModel] = passiveAgility.Value
        return true
    end
    return false
end

local function restoreAgilityValue(playerModel)
    if savedAgilityValues[playerModel] ~= nil then
        local passiveAgility = playerModel:FindFirstChild("PassiveAgility")
        if passiveAgility then
            passiveAgility.Value = savedAgilityValues[playerModel]
        end
        savedAgilityValues[playerModel] = nil
        return true
    end
    return false
end

local function restoreAllAgilityValues()
    for playerModel, originalValue in pairs(savedAgilityValues) do
        if playerModel and playerModel.Parent then
            local passiveAgility = playerModel:FindFirstChild("PassiveAgility")
            if passiveAgility then
                passiveAgility.Value = originalValue
            end
        end
    end
    savedAgilityValues = {}
end

local function enableAgilitySpoofer()
    local live = workspace:FindFirstChild("Live")
    if not live then return end
    
    local playerModel = live:FindFirstChild(LP.Name)
    if not playerModel then return end
    
    saveAgilityValue(playerModel)
    
    local passiveAgility = playerModel:FindFirstChild("PassiveAgility")
    if passiveAgility then
        passiveAgility.Value = Options.AgilitySlider.Value
    end
    
    if agilityConnection then agilityConnection:Disconnect() end
    
    agilityConnection = RunService.Heartbeat:Connect(function()
        local currentLive = workspace:FindFirstChild("Live")
        if currentLive then
            local currentPlayerModel = currentLive:FindFirstChild(LP.Name)
            if currentPlayerModel then
                local currentPassiveAgility = currentPlayerModel:FindFirstChild("PassiveAgility")
                if currentPassiveAgility then
                    if savedAgilityValues[currentPlayerModel] == nil then
                        saveAgilityValue(currentPlayerModel)
                    end
                    currentPassiveAgility.Value = Options.AgilitySlider.Value
                end
            end
        end
    end)
end

local function disableAgilitySpoofer()
    if agilityConnection then
        agilityConnection:Disconnect()
        agilityConnection = nil
    end
    restoreAllAgilityValues()
end

-- Noclip functions
local function savePartCollisionState(part)
    if not savedCollisionStates[part] then
        savedCollisionStates[part] = part.CanCollide
    end
end

local function restorePartCollisionState(part)
    if savedCollisionStates[part] ~= nil then
        part.CanCollide = savedCollisionStates[part]
        savedCollisionStates[part] = nil
    end
end

local function saveCharacterCollisionStates()
    local char = LP.Character
    if not char then return end
    
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            savePartCollisionState(part)
        end
    end
end

local function restoreCharacterCollisionStates()
    local char = LP.Character
    if not char then return end
    
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            restorePartCollisionState(part)
        end
    end
end

local function enableNoclip()
    if noclipConnection then return end
    
    saveCharacterCollisionStates()
    
    noclipConnection = RunService.Stepped:Connect(function()
        local char = LP.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end
    end)
end

local function disableNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
        restoreCharacterCollisionStates()
        
        for part, _ in pairs(savedCollisionStates) do
            if not part.Parent then
                savedCollisionStates[part] = nil
            end
        end
    end
end

-- Fullbright functions
local function saveLightingSettings()
    savedLightingSettings.Brightness = Lighting.Brightness
    savedLightingSettings.ClockTime = Lighting.ClockTime
    savedLightingSettings.TimeOfDay = Lighting.TimeOfDay
    savedLightingSettings.Ambient = Lighting.Ambient
    savedLightingSettings.OutdoorAmbient = Lighting.OutdoorAmbient
    savedLightingSettings.ColorShift_Top = Lighting.ColorShift_Top
    savedLightingSettings.ColorShift_Bottom = Lighting.ColorShift_Bottom
    
    if Lighting:FindFirstChild("AreaBrightness") then
        savedAreaBrightness = Lighting.AreaBrightness.Value
    end
end

local function restoreLightingSettings()
    Lighting.Brightness = savedLightingSettings.Brightness
    Lighting.ClockTime = savedLightingSettings.ClockTime
    Lighting.TimeOfDay = savedLightingSettings.TimeOfDay
    Lighting.Ambient = savedLightingSettings.Ambient
    Lighting.OutdoorAmbient = savedLightingSettings.OutdoorAmbient
    Lighting.ColorShift_Top = savedLightingSettings.ColorShift_Top
    Lighting.ColorShift_Bottom = savedLightingSettings.ColorShift_Bottom
    
    if Lighting:FindFirstChild("AreaBrightness") and savedAreaBrightness ~= nil then
        Lighting.AreaBrightness.Value = savedAreaBrightness
    end
end

local function enableFullbright()
    if fullbrightConnection then return end
    
    saveLightingSettings()
    
    Lighting.Brightness = 2
    Lighting.ClockTime = 14
    Lighting.TimeOfDay = "14:00:00"
    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    Lighting.ColorShift_Top = Color3.fromRGB(255, 255, 255)
    Lighting.ColorShift_Bottom = Color3.fromRGB(255, 255, 255)
    
    if Lighting:FindFirstChild("AreaBrightness") then
        Lighting.AreaBrightness.Value = 1
    end
    
    fullbrightConnection = RunService.RenderStepped:Connect(function()
        if Toggles.FullbrightToggle and Toggles.FullbrightToggle.Value then
            Lighting.Brightness = 2
            Lighting.ClockTime = 14
            Lighting.TimeOfDay = "14:00:00"
            Lighting.Ambient = Color3.fromRGB(255, 255, 255)
            Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
            Lighting.ColorShift_Top = Color3.fromRGB(255, 255, 255)
            Lighting.ColorShift_Bottom = Color3.fromRGB(255, 255, 255)
            
            if Lighting:FindFirstChild("AreaBrightness") then
                Lighting.AreaBrightness.Value = 1
            end
        end
    end)
end

local function disableFullbright()
    if fullbrightConnection then
        fullbrightConnection:Disconnect()
        fullbrightConnection = nil
    end
    restoreLightingSettings()
end

-- Void Mobs functions
local function getClosestMob()
    local live = workspace:FindFirstChild("Live")
    if not live then return nil end
    
    local lpChar = LP.Character
    if not lpChar then return nil end
    
    local lpHRP = lpChar:FindFirstChild("HumanoidRootPart")
    if not lpHRP then return nil end
    
    local closestMob = nil
    local closestDistance = MAX_DISTANCE + 1
    
    for _, model in pairs(live:GetChildren()) do
        if model:IsA("Model") and isMob(model) then
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hrp then
                local distance = (hrp.Position - lpHRP.Position).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestMob = model
                end
            end
        end
    end
    
    return closestMob, closestDistance
end

local function sendMobToVoid(mob)
    if not mob then return end
    
    local hrp = mob:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local success, result = pcall(function()
        hrp:SetNetworkOwner(LP)
    end)
    
    if success then
        local newPosition = Vector3.new(hrp.Position.X, VOID_Y_COORDINATE, hrp.Position.Z)
        hrp.CFrame = CFrame.new(newPosition)
        
        for _, part in pairs(mob:GetDescendants()) do
            if part:IsA("BasePart") and part ~= hrp then
                part.CFrame = CFrame.new(newPosition)
            end
        end
    end
end

local function enableVoidMobs()
    if voidMobsConnection then return end
    
    voidMobsConnection = RunService.Heartbeat:Connect(function()
        if not Toggles.VoidMobsToggle or not Toggles.VoidMobsToggle.Value then return end
        
        local closestMob, distance = getClosestMob()
        if closestMob and distance <= MAX_DISTANCE then
            sendMobToVoid(closestMob)
        end
    end)
end

local function disableVoidMobs()
    if voidMobsConnection then
        voidMobsConnection:Disconnect()
        voidMobsConnection = nil
    end
end

-- FPS and MS counter functions
local function updateFPSCounter()
    frameCount = frameCount + 1
    local currentTime = tick()
    local deltaTime = currentTime - lastFPSTime
    
    if deltaTime >= 0.5 then
        fps = math.floor(frameCount / deltaTime)
        frameCount = 0
        lastFPSTime = currentTime
        
        if Toggles.ShowFPS and Toggles.ShowFPS.Value then
            local fpsColor = Color3.fromRGB(255, 255, 255)
            if fps < 30 then
                fpsColor = Color3.fromRGB(255, 50, 50)
            elseif fps < 60 then
                fpsColor = Color3.fromRGB(255, 200, 50)
            else
                fpsColor = Color3.fromRGB(50, 255, 50)
            end
            
            fpsCounter.Text = string.format("FPS: %d", fps)
            fpsCounter.Color = fpsColor
        end
    end
    
    if Toggles.ShowPing and Toggles.ShowPing.Value then
        if currentTime - lastPingUpdate > 1 then
            currentPing = Stats.PerformanceStats.Ping:GetValue()
            lastPingUpdate = currentTime
            
            local pingColor = Color3.fromRGB(255, 255, 255)
            if currentPing > 150 then
                pingColor = Color3.fromRGB(255, 50, 50)
            elseif currentPing > 80 then
                pingColor = Color3.fromRGB(255, 200, 50)
            else
                pingColor = Color3.fromRGB(50, 255, 50)
            end
            
            pingCounter.Color = pingColor
        end
        pingCounter.Text = string.format("Ping: %.0fms", currentPing)
    end
end

local function updateCounterPositions()
    local posX = Options.FPSPingPositionX.Value
    local posY = Options.FPSPingPositionY.Value
    local spacing = Options.FPSPingSpacing.Value
    
    if Toggles.ShowFPS and Toggles.ShowFPS.Value and Toggles.ShowPing and Toggles.ShowPing.Value then
        fpsCounter.Position = Vector2.new(posX, posY)
        pingCounter.Position = Vector2.new(posX, posY + spacing)
    elseif Toggles.ShowFPS and Toggles.ShowFPS.Value then
        fpsCounter.Position = Vector2.new(posX, posY)
    elseif Toggles.ShowPing and Toggles.ShowPing.Value then
        pingCounter.Position = Vector2.new(posX, posY)
    end
end

-- Teleport functions
local function teleportToRealm(realmName, teleportConnectionVar, isTeleportingVar)
    if isTeleportingVar then
        if teleportConnectionVar then
            teleportConnectionVar:Disconnect()
            teleportConnectionVar = nil
        end
        isTeleportingVar = false
        return false
    end
    
    isTeleportingVar = true
    
    local function findRealmTeleporter()
        local teleporter = workspace:FindFirstChild("RealmTeleporter")
        if teleporter then return teleporter end
        
        for _, child in pairs(workspace:GetChildren()) do
            if child.Name and string.find(string.lower(child.Name), string.lower(realmName)) then
                return child
            end
        end
        
        return nil
    end
    
    local function teleportViaCFrame(teleporter)
        local char = LP.Character
        if not char then return false end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        hrp.CFrame = teleporter.CFrame
        return true
    end
    
    local function teleportViaTween(teleporter)
        local char = LP.Character
        if not char then return false end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = teleporter.CFrame})
        tween:Play()
        return true
    end
    
    local teleporter = findRealmTeleporter()
    if teleporter then
        teleportViaCFrame(teleporter)
        task.wait(0.1)
        teleportViaTween(teleporter)
    end
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not isTeleportingVar then
            if connection then
                connection:Disconnect()
            end
            return
        end
        
        local currentTeleporter = findRealmTeleporter()
        if currentTeleporter then
            teleportViaCFrame(currentTeleporter)
        end
    end)
    
    task.delay(10, function()
        if isTeleportingVar then
            isTeleportingVar = false
            if connection then
                connection:Disconnect()
            end
        end
    end)
    
    return true
end

local function teleportToEtreanLuminant()
    teleportToRealm("Etrean", etreanTeleportConnection, isTeleportingToEtrean)
end

local function teleportToEasternLuminant()
    teleportToRealm("Eastern", easternTeleportConnection, isTeleportingToEastern)
end

local function hpColor(pct)
    if pct > 0.5 then
        return Color3.fromRGB(math.floor(255 * (1 - pct) * 2), 255, 0)
    else
        return Color3.fromRGB(255, math.floor(255 * pct * 2), 0)
    end
end

local function createEntry(storage, model, nameColor, distColor, fillColor, hasHP)
    if storage[model] then return end

    local nameLabel = Drawing.new("Text")
    nameLabel.Visible = false
    nameLabel.Text = model.Name
    nameLabel.Size = 14
    nameLabel.Center = true
    nameLabel.Outline = true
    nameLabel.OutlineColor = Color3.fromRGB(0, 0, 0)
    nameLabel.Color = nameColor
    nameLabel.Font = Drawing.Fonts.UI

    local distLabel = Drawing.new("Text")
    distLabel.Visible = false
    distLabel.Text = "0m"
    distLabel.Size = 12
    distLabel.Center = true
    distLabel.Outline = true
    distLabel.OutlineColor = Color3.fromRGB(0, 0, 0)
    distLabel.Color = distColor
    distLabel.Font = Drawing.Fonts.UI

    local hpLabel = nil
    if hasHP then
        hpLabel = Drawing.new("Text")
        hpLabel.Visible = false
        hpLabel.Text = "100%"
        hpLabel.Size = 12
        hpLabel.Center = true
        hpLabel.Outline = true
        hpLabel.OutlineColor = Color3.fromRGB(0, 0, 0)
        hpLabel.Color = Color3.fromRGB(0, 255, 0)
        hpLabel.Font = Drawing.Fonts.UI
    end

    local highlight = Instance.new("Highlight")
    highlight.FillColor = fillColor
    highlight.OutlineColor = fillColor
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = false
    highlight.Parent = model

    storage[model] = { 
        name = nameLabel, 
        dist = distLabel, 
        hp = hpLabel, 
        highlight = highlight, 
        hasHP = hasHP,
        model = model
    }
end

local function removeEntry(storage, model)
    if storage[model] then
        storage[model].name:Remove()
        storage[model].dist:Remove()
        if storage[model].hp then
            storage[model].hp:Remove()
        end
        if storage[model].highlight and storage[model].highlight.Parent then
            storage[model].highlight:Destroy()
        end
        storage[model] = nil
    end
end

local function updateLabels(storage, toggleKey, distToggleKey, hpToggleKey, highlightToggleKey, nameColorKey, distColorKey, fillColorKey, sizeKey, fillTransKey, maxDistKey, masterEnabled)
    if not masterEnabled then
        return
    end
    
    if next(storage) == nil then return end
    
    local maxDistance = Options[maxDistKey] and Options[maxDistKey].Value or math.huge
    local showName = Toggles[toggleKey] and Toggles[toggleKey].Value or false
    local showDist = Toggles[distToggleKey] and Toggles[distToggleKey].Value or false
    local showHighlight = Toggles[highlightToggleKey] and Toggles[highlightToggleKey].Value or false
    local showHP = hpToggleKey and Toggles[hpToggleKey] and Toggles[hpToggleKey].Value or false
    
    local nameColor = Options[nameColorKey].Value
    local distColor = Options[distColorKey].Value
    local fillColor = Options[fillColorKey].Value
    local fillTrans = Options[fillTransKey].Value
    local textSize = Options[sizeKey].Value
    
    lpChar = LP.Character
    lpHRP = lpChar and lpChar:FindFirstChild("HumanoidRootPart")

    for model, entry in pairs(storage) do
        if not model.Parent then
            removeEntry(storage, model)
            continue
        end

        local hrp = model:FindFirstChild("HumanoidRootPart")
        if not hrp then
            entry.name.Visible = false
            entry.dist.Visible = false
            if entry.hp then entry.hp.Visible = false end
            entry.highlight.Enabled = false
            continue
        end

        if lpChar and model == lpChar then
            entry.name.Visible = false
            entry.dist.Visible = false
            if entry.hp then entry.hp.Visible = false end
            entry.highlight.Enabled = false
            continue
        end

        local hum = nil
        if entry.hasHP and showHP then
            hum = model:FindFirstChildOfClass("Humanoid")
            if not hum then
                entry.name.Visible = false
                entry.dist.Visible = false
                if entry.hp then entry.hp.Visible = false end
                entry.highlight.Enabled = false
                continue
            end
        end

        if lpHRP then
            local distance = (hrp.Position - lpHRP.Position).Magnitude
            if distance > maxDistance then
                entry.name.Visible = false
                entry.dist.Visible = false
                if entry.hp then entry.hp.Visible = false end
                entry.highlight.Enabled = false
                continue
            end
            distCache[model] = distance
        end

        entry.highlight.Enabled = showHighlight
        if showHighlight then
            entry.highlight.FillColor = fillColor
            entry.highlight.OutlineColor = fillColor
            entry.highlight.FillTransparency = fillTrans
        end

        if showName or showDist or (showHP and entry.hasHP) then
            local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3.2, 0))
            
            if not onScreen then
                entry.name.Visible = false
                entry.dist.Visible = false
                if entry.hp then entry.hp.Visible = false end
                continue
            end

            local lineGap = textSize + 2
            local currentY = screenPos.Y

            if showName then
                entry.name.Position = Vector2.new(screenPos.X, currentY)
                entry.name.Color = nameColor
                entry.name.Size = textSize
                entry.name.Visible = true
                currentY = currentY + lineGap
            else
                entry.name.Visible = false
            end

            if showDist and distCache[model] then
                entry.dist.Text = math.floor(distCache[model]) .. "m"
                entry.dist.Color = distColor
                entry.dist.Size = textSize - 2
                entry.dist.Position = Vector2.new(screenPos.X, currentY)
                entry.dist.Visible = true
                currentY = currentY + lineGap
            else
                entry.dist.Visible = false
            end

            if entry.hp and hum and showHP then
                local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                entry.hp.Text = math.floor(pct * 100) .. "%"
                entry.hp.Color = hpColor(pct)
                entry.hp.Size = textSize - 2
                entry.hp.Position = Vector2.new(screenPos.X, currentY)
                entry.hp.Visible = true
            elseif entry.hp then
                entry.hp.Visible = false
            end
        else
            entry.name.Visible = false
            entry.dist.Visible = false
            if entry.hp then entry.hp.Visible = false end
        end
    end
    
    distCache = {}
end

local function forceHideESP()
    if not espPlayersMasterEnabled then
        for model, entry in pairs(espPlayers) do
            if entry then
                entry.name.Visible = false
                entry.dist.Visible = false
                if entry.hp then entry.hp.Visible = false end
                if entry.highlight then
                    entry.highlight.Enabled = false
                end
            end
        end
    end
    
    if not espMobsMasterEnabled then
        for model, entry in pairs(espMobs) do
            if entry then
                entry.name.Visible = false
                entry.dist.Visible = false
                if entry.hp then entry.hp.Visible = false end
                if entry.highlight then
                    entry.highlight.Enabled = false
                end
            end
        end
    end
    
    if not espNPCsMasterEnabled then
        for model, entry in pairs(espNPCs) do
            if entry then
                entry.name.Visible = false
                entry.dist.Visible = false
                if entry.hp then entry.hp.Visible = false end
                if entry.highlight then
                    entry.highlight.Enabled = false
                end
            end
        end
    end
end

local function updateAllESP()
    local currentTime = tick()
    if currentTime - lastESPUpdate < ESP_UPDATE_INTERVAL then
        return
    end
    lastESPUpdate = currentTime
    
    updateLabels(espPlayers,
        'ESPToggle', 'ESPDistToggle', 'ESPHPToggle', 'ESPHighlightToggle',
        'ESPColor', 'ESPDistColor', 'ESPFillColor',
        'ESPSize', 'ESPFillTrans', 'ESPMaxDistance',
        espPlayersMasterEnabled)

    updateLabels(espMobs,
        'MobESPToggle', 'MobESPDistToggle', 'MobESPHPToggle', 'MobESPHighlightToggle',
        'MobESPColor', 'MobESPDistColor', 'MobESPFillColor',
        'MobESPSize', 'MobESPFillTrans', 'MobESPMaxDistance',
        espMobsMasterEnabled)
        
    updateLabels(espNPCs,
        'NPCEPToggle', 'NPCEspDistToggle', nil, 'NPCEspHighlightToggle',
        'NPCEspColor', 'NPCEspDistColor', 'NPCEspFillColor',
        'NPCEspSize', 'NPCEspFillTrans', 'NPCEspMaxDistance',
        espNPCsMasterEnabled)
end

-- Watch for NPCs in Workspace.NPCs
local function watchNPCs()
    local npcContainer = workspace:FindFirstChild("NPCs")
    if not npcContainer then
        local npcAddedConnection
        npcAddedConnection = workspace.ChildAdded:Connect(function(child)
            if child.Name == "NPCs" then
                npcContainer = child
                npcAddedConnection:Disconnect()
                
                for _, npc in pairs(npcContainer:GetChildren()) do
                    if npc:IsA("Model") then
                        createEntry(espNPCs, npc,
                            Color3.fromRGB(160, 32, 240),
                            Color3.fromRGB(200, 100, 255),
                            Color3.fromRGB(128, 0, 255),
                            false)
                    end
                end
                
                npcContainer.ChildAdded:Connect(function(npc)
                    if npc:IsA("Model") then
                        createEntry(espNPCs, npc,
                            Color3.fromRGB(160, 32, 240),
                            Color3.fromRGB(200, 100, 255),
                            Color3.fromRGB(128, 0, 255),
                            false)
                    end
                end)
                
                npcContainer.ChildRemoved:Connect(function(npc)
                    removeEntry(espNPCs, npc)
                end)
            end
        end)
        
        task.delay(30, function()
            if npcAddedConnection then
                npcAddedConnection:Disconnect()
            end
        end)
        return
    end
    
    for _, npc in pairs(npcContainer:GetChildren()) do
        if npc:IsA("Model") then
            createEntry(espNPCs, npc,
                Color3.fromRGB(160, 32, 240),
                Color3.fromRGB(200, 100, 255),
                Color3.fromRGB(128, 0, 255),
                false)
        end
    end
    
    npcContainer.ChildAdded:Connect(function(npc)
        if npc:IsA("Model") then
            createEntry(espNPCs, npc,
                Color3.fromRGB(160, 32, 240),
                Color3.fromRGB(200, 100, 255),
                Color3.fromRGB(128, 0, 255),
                false)
        end
    end)
    
    npcContainer.ChildRemoved:Connect(function(npc)
        removeEntry(espNPCs, npc)
    end)
end

local function watchLive()
    local live = workspace:WaitForChild("Live", 10)
    if not live then return end

    for _, model in ipairs(live:GetChildren()) do
        if not model:IsA("Model") then continue end
        if isMob(model) then
            createEntry(espMobs, model,
                Color3.fromRGB(255, 100, 100), Color3.fromRGB(255, 180, 180),
                Color3.fromRGB(255, 50, 50), true)
        else
            createEntry(espPlayers, model,
                Color3.fromRGB(255, 255, 255), Color3.fromRGB(180, 220, 255),
                Color3.fromRGB(50, 100, 255), true)
        end
    end

    live.ChildAdded:Connect(function(child)
        if not child:IsA("Model") then return end
        if isMob(child) then
            createEntry(espMobs, child,
                Color3.fromRGB(255, 100, 100), Color3.fromRGB(255, 180, 180),
                Color3.fromRGB(255, 50, 50), true)
        else
            createEntry(espPlayers, child,
                Color3.fromRGB(255, 255, 255), Color3.fromRGB(180, 220, 255),
                Color3.fromRGB(50, 100, 255), true)
        end
    end)

    live.ChildRemoved:Connect(function(child)
        removeEntry(espPlayers, child)
        removeEntry(espMobs, child)
    end)
end

task.spawn(watchLive)
task.spawn(watchNPCs)

