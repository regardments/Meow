-- Agility spoofer variables
local agilityConnection = nil
local savedAgilityValues = {}

-- Noclip variables
local noclipConnection = nil
local savedCollisionStates = {}

-- Fullbright variables
local fullbrightConnection = nil
local savedLightingSettings = {
    Brightness = nil,
    ClockTime = nil,
    TimeOfDay = nil,
    Ambient = nil,
    OutdoorAmbient = nil,
    ColorShift_Top = nil,
    ColorShift_Bottom = nil
