-- RenderStepped
RunService.RenderStepped:Connect(function()
    updateFPSCounter()
    
    if Toggles.FlyToggle.Value then
        local char = LP.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp and St.flyBV then
                local cam = workspace.CurrentCamera
                if cam then
                    local dir = Vector3.zero

                    if UserInput:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
                    if UserInput:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
                    if UserInput:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
                    if UserInput:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end
                    if UserInput:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0, 1, 0) end
                    if UserInput:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.new(0, 1, 0) end

                    St.flyBV.Velocity = if dir.Magnitude > 0 then dir.Unit * flySpeed else Vector3.zero
                end
            end
        end
    end

    updateAllESP()
end)

LP.CharacterAdded:Connect(function()
    task.wait(1)
    if Toggles.FlyToggle.Value then startFly() end
    if Toggles.NoclipToggle.Value then enableNoclip() end
end)

LP.AncestryChanged:Connect(function()
    disableAgilitySpoofer()
    disableNoclip()
    stopFly()
    if Toggles.FullbrightToggle and Toggles.FullbrightToggle.Value then
        disableFullbright()
        Toggles.FullbrightToggle:SetValue(false)
    end
    if etreanTeleportConnection then
        etreanTeleportConnection:Disconnect()
        etreanTeleportConnection = nil
    end
    isTeleportingToEtrean = false
    if easternTeleportConnection then
        easternTeleportConnection:Disconnect()
        easternTeleportConnection = nil
    end
    isTeleportingToEastern = false
end)

-- UI Settings
local MenuGroup = Tabs['UI Settings']:AddLeftGroupbox('Menu')
MenuGroup:AddButton('Unload', function()
    espPlayersMasterEnabled = false
    espMobsMasterEnabled = false
    espNPCsMasterEnabled = false
    disableAgilitySpoofer()
    disableNoclip()
    stopFly()
    if Toggles.FullbrightToggle and Toggles.FullbrightToggle.Value then
        disableFullbright()
    end
    
    fpsCounter:Remove()
    pingCounter:Remove()
    
    if etreanTeleportConnection then
        etreanTeleportConnection:Disconnect()
        etreanTeleportConnection = nil
    end
    isTeleportingToEtrean = false
    if easternTeleportConnection then
        easternTeleportConnection:Disconnect()
        easternTeleportConnection = nil
    end
    isTeleportingToEastern = false
    
    for _, e in pairs(espPlayers) do
        if e then
            e.name:Remove()
            e.dist:Remove()
            if e.hp then e.hp:Remove() end
            if e.highlight and e.highlight.Parent then
                e.highlight:Destroy()
            end
        end
    end
    for _, e in pairs(espMobs) do
        if e then
            e.name:Remove()
            e.dist:Remove()
            if e.hp then e.hp:Remove() end
            if e.highlight and e.highlight.Parent then
                e.highlight:Destroy()
            end
        end
    end
    for _, e in pairs(espNPCs) do
        if e then
            e.name:Remove()
            e.dist:Remove()
            if e.hp then e.hp:Remove() end
            if e.highlight and e.highlight.Parent then
                e.highlight:Destroy()
            end
        end
    end
    Library:Unload()
end)

MenuGroup:AddLabel('Menu bind'):AddKeyPicker('MenuKeybind', { 
    Default = 'RightShift', 
    NoUI = true, 
    Text = 'Menu keybind' 
})
Library.ToggleKeybind = Options.MenuKeybind

