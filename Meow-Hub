-- Get player's current Intelligence stat
local function getCurrentIntelligence()
    local localPlayer = Players.LocalPlayer
    local character = localPlayer.Character
    if not character then return 0 end
    
    local statIntelligence = character:FindFirstChild("Stat_Intelligence")
    if statIntelligence and type(statIntelligence.Value) == "number" then
        return statIntelligence.Value
    end
    
    return 0
