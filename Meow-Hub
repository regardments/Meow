-- FPS and MS counter functions
local function updateFPSCounter()
    frameCount = frameCount + 1
    local currentTime = tick()
    local deltaTime = currentTime - lastFPSTime
    
    if deltaTime >= 0.5 then
        fps = math.floor(frameCount / deltaTime)
        frameCount = 0
        lastFPSTime = currentTime
        
        if Toggles.ShowFPS and Toggles.ShowFPS.Value then
            local fpsColor = Color3.fromRGB(255, 255, 255)
            if fps < 30 then
                fpsColor = Color3.fromRGB(255, 50, 50)
            elseif fps < 60 then
                fpsColor = Color3.fromRGB(255, 200, 50)
            else
                fpsColor = Color3.fromRGB(50, 255, 50)
            end
            
            fpsCounter.Text = string.format("FPS: %d", fps)
            fpsCounter.Color = fpsColor
        end
    end
    
    if Toggles.ShowPing and Toggles.ShowPing.Value then
        if currentTime - lastPingUpdate > 1 then
            currentPing = Stats.PerformanceStats.Ping:GetValue()
            lastPingUpdate = currentTime
            
            local pingColor = Color3.fromRGB(255, 255, 255)
            if currentPing > 150 then
                pingColor = Color3.fromRGB(255, 50, 50)
            elseif currentPing > 80 then
                pingColor = Color3.fromRGB(255, 200, 50)
            else
                pingColor = Color3.fromRGB(50, 255, 50)
            end
            
            pingCounter.Color = pingColor
        end
        pingCounter.Text = string.format("Ping: %.0fms", currentPing)
    end
end

local function updateCounterPositions()
    local posX = Options.FPSPingPositionX.Value
    local posY = Options.FPSPingPositionY.Value
    local spacing = Options.FPSPingSpacing.Value
    
    if Toggles.ShowFPS and Toggles.ShowFPS.Value and Toggles.ShowPing and Toggles.ShowPing.Value then
        fpsCounter.Position = Vector2.new(posX, posY)
        pingCounter.Position = Vector2.new(posX, posY + spacing)
    elseif Toggles.ShowFPS and Toggles.ShowFPS.Value then
        fpsCounter.Position = Vector2.new(posX, posY)
    elseif Toggles.ShowPing and Toggles.ShowPing.Value then
        pingCounter.Position = Vector2.new(posX, posY)
    end
end

-- Teleport functions
local function teleportToRealm(realmName, teleportConnectionVar, isTeleportingVar)
    if isTeleportingVar then
        if teleportConnectionVar then
            teleportConnectionVar:Disconnect()
            teleportConnectionVar = nil
        end
        isTeleportingVar = false
        return false
    end
    
    isTeleportingVar = true
    
    local function findRealmTeleporter()
        local teleporter = workspace:FindFirstChild("RealmTeleporter")
        if teleporter then return teleporter end
        
        for _, child in pairs(workspace:GetChildren()) do
            if child.Name and string.find(string.lower(child.Name), string.lower(realmName)) then
                return child
            end
        end
        
        return nil
    end
    
    local function teleportViaCFrame(teleporter)
        local char = LP.Character
        if not char then return false end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        hrp.CFrame = teleporter.CFrame
        return true
    end
    
    local function teleportViaTween(teleporter)
        local char = LP.Character
        if not char then return false end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        
        local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = teleporter.CFrame})
        tween:Play()
        return true
    end
    
    local teleporter = findRealmTeleporter()
    if teleporter then
        teleportViaCFrame(teleporter)
        task.wait(0.1)
        teleportViaTween(teleporter)
    end
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not isTeleportingVar then
            if connection then
                connection:Disconnect()
            end
            return
        end
        
        local currentTeleporter = findRealmTeleporter()
        if currentTeleporter then
            teleportViaCFrame(currentTeleporter)
        end
    end)
    
    task.delay(10, function()
        if isTeleportingVar then
            isTeleportingVar = false
            if connection then
                connection:Disconnect()
            end
        end
    end)
    
    return true
end

