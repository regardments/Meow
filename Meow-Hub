-- Void Mobs functions
local function getClosestMob()
    local live = workspace:FindFirstChild("Live")
    if not live then return nil end
    
    local lpChar = LP.Character
    if not lpChar then return nil end
    
    local lpHRP = lpChar:FindFirstChild("HumanoidRootPart")
    if not lpHRP then return nil end
    
    local closestMob = nil
    local closestDistance = MAX_DISTANCE + 1
    
    for _, model in pairs(live:GetChildren()) do
        if model:IsA("Model") and isMob(model) then
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hrp then
                local distance = (hrp.Position - lpHRP.Position).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestMob = model
                end
            end
        end
    end
    
    return closestMob, closestDistance
end

local function sendMobToVoid(mob)
    if not mob then return end
    
    local hrp = mob:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local success, result = pcall(function()
        hrp:SetNetworkOwner(LP)
    end)
    
    if success then
        local newPosition = Vector3.new(hrp.Position.X, VOID_Y_COORDINATE, hrp.Position.Z)
        hrp.CFrame = CFrame.new(newPosition)
        
        for _, part in pairs(mob:GetDescendants()) do
            if part:IsA("BasePart") and part ~= hrp then
                part.CFrame = CFrame.new(newPosition)
            end
        end
    end
end

local function enableVoidMobs()
    if voidMobsConnection then return end
    
    voidMobsConnection = RunService.Heartbeat:Connect(function()
        if not Toggles.VoidMobsToggle or not Toggles.VoidMobsToggle.Value then return end
        
        local closestMob, distance = getClosestMob()
        if closestMob and distance <= MAX_DISTANCE then
            sendMobToVoid(closestMob)
        end
    end)
end

local function disableVoidMobs()
    if voidMobsConnection then
        voidMobsConnection:Disconnect()
        voidMobsConnection = nil
    end
end

-- ============ INTELLIGENCE FARMING FUNCTIONS ============
local function updateIntelligence()
    if not Toggles.AutoIntelligence or not Toggles.AutoIntelligence.Value then
        return
    end
    
    local intelligenceCap = Options.IntelligenceCap
    if not intelligenceCap then
        return
    end
    
    local currentIntelligence = getCurrentIntelligence()
    local targetCap = intelligenceCap.Value
    
    if currentIntelligence >= targetCap then
        Logger("Intelligence AutoFarm reached cap (" .. targetCap .. "), current: " .. currentIntelligence .. ", stopping.")
        Toggles.AutoIntelligence:SetValue(false)
        return
    end
    
    local localPlayer = Players.LocalPlayer
    local localPlayerCharacter = localPlayer.Character
    if not localPlayerCharacter then
        return
    end
    
    local humanoid = localPlayerCharacter:FindFirstChild("Humanoid")
    if not humanoid then
        return
    end
    
    local backpack = localPlayer:FindFirstChild("Backpack")
    if not backpack then
        return
    end
    
    local characterBook = localPlayerCharacter:FindFirstChild("Math Textbook")
    local backpackBook = backpack:FindFirstChild("Math Textbook")
    
    if not characterBook and backpackBook then
        humanoid:EquipTool(backpackBook)
        return
    end
    
    local choicePrompt = localPlayer.PlayerGui:FindFirstChild("ChoicePrompt")
    if not choicePrompt then
        if characterBook then
            characterBook:Activate()
        end
        return
    end
    
    local choiceRemote = choicePrompt:FindFirstChild("Choice")
    if not choiceRemote then
        return
    end
    
    local choiceFrame = choicePrompt:FindFirstChild("ChoiceFrame")
    if not choiceFrame then
        return
    end
    
    local descSheet = choiceFrame:FindFirstChild("DescSheet")
    local description = descSheet and descSheet:FindFirstChild("Desc")
    if not description then
        return
    end
    
    local options = choiceFrame:FindFirstChild("Options")
    if not options then
        return
    end
    
    local answers = {}
    
    for _, instance in next, options:GetChildren() do
        if not instance:IsA("TextButton") then
            continue
        end
        
        local number = tonumber(instance.Name)
        if not number then
            continue
        end
        
        table.insert(answers, number)
    end
    
    local descriptionText = tostring(description.Text)
    local parsedDescription = descriptionText:gsub("What is", ""):gsub(" ", ""):gsub("?", ""):gsub("by", "")
    
    local operation = nil
    
    if parsedDescription:find("divided") then
        operation = "divided"
    elseif parsedDescription:find("times") then
        operation = "times"
    elseif parsedDescription:find("plus") then
        operation = "plus"
    elseif parsedDescription:find("minus") then
        operation = "minus"
    end
    
    if not operation then
        return
    end
    
    local firstNumber = nil
    local secondNumber = nil
    
    if operation == "divided" then
        local parts = {}
        local splitIndex = parsedDescription:find("divided")
        if splitIndex then
            parts[1] = parsedDescription:sub(1, splitIndex - 1)
            parts[2] = parsedDescription:sub(splitIndex + #"divided")
        end
        firstNumber = tonumber(parts[1])
        secondNumber = tonumber(parts[2])
    elseif operation == "times" then
        local parts = {}
        local splitIndex = parsedDescription:find("times")
        if splitIndex then
            parts[1] = parsedDescription:sub(1, splitIndex - 1)
            parts[2] = parsedDescription:sub(splitIndex + #"times")
        end
        firstNumber = tonumber(parts[1])
        secondNumber = tonumber(parts[2])
    elseif operation == "plus" then
        local parts = {}
        local splitIndex = parsedDescription:find("plus")
        if splitIndex then
            parts[1] = parsedDescription:sub(1, splitIndex - 1)
            parts[2] = parsedDescription:sub(splitIndex + #"plus")
        end
        firstNumber = tonumber(parts[1])
        secondNumber = tonumber(parts[2])
    elseif operation == "minus" then
        local parts = {}
        local splitIndex = parsedDescription:find("minus")
        if splitIndex then
            parts[1] = parsedDescription:sub(1, splitIndex - 1)
            parts[2] = parsedDescription:sub(splitIndex + #"minus")
        end
        firstNumber = tonumber(parts[1])
        secondNumber = tonumber(parts[2])
    end
    
    if not firstNumber or not secondNumber then
        return
    end
    
    local answer = nil
    
    if operation == "divided" then
        answer = firstNumber / secondNumber
    elseif operation == "times" then
        answer = firstNumber * secondNumber
    elseif operation == "plus" then
        answer = firstNumber + secondNumber
    elseif operation == "minus" then
        answer = firstNumber - secondNumber
    end
    
    local closestAnswer = nil
    local closestDifference = nil
    
    for _, possible in next, answers do
        local delta = math.abs(answer - possible)
        
        if closestDifference == nil or delta < closestDifference then
            closestAnswer = possible
            closestDifference = delta
        end
    end
    
    if not closestAnswer then
        return
    end
    
    choiceRemote:FireServer(tostring(closestAnswer))
end

