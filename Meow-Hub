-- FFlags functions
local function downgradeObject(obj)
    if obj:IsA("BasePart") then
        obj.Material = Enum.Material.Plastic
        obj.Reflectance = 0
        obj.CastShadow = false
    end
    
    if obj:IsA("Texture") or obj:IsA("Decal") then
        obj.Texture = LOW_TEXTURE
    elseif obj:IsA("SurfaceAppearance") then
        obj.ColorMap = LOW_TEXTURE
        obj.MetalnessMap = ""
        obj.RoughnessMap = ""
        obj.NormalMap = ""
    end

    if obj:IsA("ParticleEmitter") then
        obj.Enabled = false
        obj.Rate = 0
        obj.Speed = NumberRange.new(0)
    end

    if obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
        obj.Enabled = false
        obj.Brightness = 0
        obj.Range = 2
    end

    if obj:IsA("BloomEffect") 
        or obj:IsA("BlurEffect")
        or obj:IsA("ColorCorrectionEffect")
        or obj:IsA("SunRaysEffect")
        or obj:IsA("DepthOfFieldEffect")
    then
        obj.Enabled = false
    end
end

local function enableFFlags()
    if fflagsActive then return end
    
    Lighting.GlobalShadows = false
    Lighting.Brightness = 1
    Lighting.Ambient = Color3.new(1, 1, 1)
    Lighting.OutdoorAmbient = Color3.new(1, 1, 1)

    local atmo = Lighting:FindFirstChildOfClass("Atmosphere")
    if atmo then
        atmo.Density = 0
        atmo.Haze = 0
        atmo.Glare = 0
    end

    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("BloomEffect")
        or effect:IsA("BlurEffect")
        or effect:IsA("ColorCorrectionEffect")
        or effect:IsA("SunRaysEffect")
        or effect:IsA("DepthOfFieldEffect") then
            effect.Enabled = false
        end
    end

    pcall(function()
        workspace.Terrain.WaterTransparency = 1
        workspace.Terrain.WaterReflectance = 0
    end)

    task.spawn(function()
        for _, obj in ipairs(game:GetDescendants()) do
            downgradeObject(obj)
        end
    end)

    fflagsConnection = game.DescendantAdded:Connect(function(obj)
        task.defer(function()
            downgradeObject(obj)
        end)
    end)
    
    fflagsActive = true
end

local function disableFFlags()
    if not fflagsActive then return end
    
    if fflagsConnection then
        fflagsConnection:Disconnect()
        fflagsConnection = nil
    end
    
    fflagsActive = false
    warn("FFlags disabled but some visual changes may persist. Reload the script to fully revert.")
end

-- Fullbright functions
local function saveEffectStates()
    originalEffectStates = {}
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("Atmosphere") or effect:IsA("BlurEffect") or effect:IsA("ColorCorrectionEffect") then
            originalEffectStates[effect] = effect.Enabled
        end
    end
end

local function restoreEffectStates()
    for effect, wasEnabled in pairs(originalEffectStates) do
        if effect and effect.Parent then
            effect.Enabled = wasEnabled
        end
    end
    originalEffectStates = {}
end

local function applyFullbright()
    Lighting.Brightness = 2
    Lighting.Ambient = Color3.fromRGB(178, 178, 178)
    Lighting.OutdoorAmbient = Color3.fromRGB(178, 178, 178)
    Lighting.ClockTime = 12
    
    for _, effect in ipairs(Lighting:GetChildren()) do
        if effect:IsA("Atmosphere") or effect:IsA("BlurEffect") or effect:IsA("ColorCorrectionEffect") then
            effect.Enabled = false
        end
    end
end

local function enableFullbright()
    if fullbrightActive then return end
    
    originalBrightness = Lighting.Brightness
    originalAmbient = Lighting.Ambient
    originalOutdoorAmbient = Lighting.OutdoorAmbient
    originalClockTime = Lighting.ClockTime
    saveEffectStates()
    
    applyFullbright()
    fullbrightActive = true
end

local function disableFullbright()
    if not fullbrightActive then return end
    
    if originalBrightness then Lighting.Brightness = originalBrightness end
    if originalAmbient then Lighting.Ambient = originalAmbient end
    if originalOutdoorAmbient then Lighting.OutdoorAmbient = originalOutdoorAmbient end
    if originalClockTime then Lighting.ClockTime = originalClockTime end
    
    restoreEffectStates()
    fullbrightActive = false
end

