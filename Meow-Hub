-- ============ INTELLIGENCE FARMING FUNCTIONS ============
local function updateIntelligence()
    if not Toggles.AutoIntelligence or not Toggles.AutoIntelligence.Value then
        return
    end
    
    local intelligenceCap = Options.IntelligenceCap
    if not intelligenceCap then
        return
    end
    
    local localPlayer = LP
    local localPlayerCharacter = localPlayer.Character
    if not localPlayerCharacter then
        return
    end
    
    local statIntelligence = localPlayerCharacter:FindFirstChild("Stat_Intelligence")
    if statIntelligence and statIntelligence.Value >= intelligenceCap.Value then
        if isIntelligenceFarming then
            print("[Meow Hub] Intelligence AutoFarm reached cap and is stopping.")
            Toggles.AutoIntelligence:SetValue(false)
        end
        return
    end
    
    local humanoid = localPlayerCharacter:FindFirstChild("Humanoid")
    if not humanoid then
        return
    end
    
    local backpack = localPlayer:FindFirstChild("Backpack")
    local characterBook = localPlayerCharacter:FindFirstChild("Math Textbook")
    local backpackBook = backpack and backpack:FindFirstChild("Math Textbook")
    
    if not characterBook and backpackBook then
        humanoid:EquipTool(backpackBook)
        return
    end
    
    local choicePrompt = localPlayer.PlayerGui:FindFirstChild("ChoicePrompt")
    if not choicePrompt then
        if characterBook then
            characterBook:Activate()
        end
        return
    end
    
    local choiceRemote = choicePrompt:FindFirstChild("Choice")
    local choiceFrame = choicePrompt:FindFirstChild("ChoiceFrame")
    if not choiceRemote or not choiceFrame then
        return
    end
    
    local descSheet = choiceFrame:FindFirstChild("DescSheet")
    local description = descSheet and descSheet:FindFirstChild("Desc")
    local options = choiceFrame:FindFirstChild("Options")
    
    if not description or not options then
        return
    end
    
    local answers = {}
    for _, instance in next, options:GetChildren() do
        if instance:IsA("TextButton") then
            local number = tonumber(instance.Name)
            if number then
                table.insert(answers, number)
            end
        end
    end
    
    if #answers == 0 then
        return
    end
    
    local descriptionText = tostring(description.Text)
    local cleanText = descriptionText:gsub("What is", ""):gsub("?", ""):gsub(" ", ""):gsub("by", ""):lower()
    
    local operation = nil
    if cleanText:find("divided") then
        operation = "divided"
    elseif cleanText:find("times") then
        operation = "times"
    elseif cleanText:find("plus") then
        operation = "plus"
    elseif cleanText:find("minus") then
        operation = "minus"
    end
    
    if not operation then
        return
    end
    
    local parsedNumbers = splitString(cleanText, operation)
    local firstNumber = tonumber(parsedNumbers[1])
    local secondNumber = tonumber(parsedNumbers[2])
    
    if not firstNumber or not secondNumber then
        return
    end
    
    if operation == "divided" and secondNumber == 0 then
        return
    end
    
    local answer = nil
    if operation == "divided" then
        answer = firstNumber / secondNumber
        local rounded = math.floor(answer + 0.5)
        if math.abs(answer - rounded) < 0.01 then
            answer = rounded
        end
    elseif operation == "times" then
        answer = firstNumber * secondNumber
    elseif operation == "plus" then
        answer = firstNumber + secondNumber
    elseif operation == "minus" then
        answer = firstNumber - secondNumber
    end
    
    local closestAnswer = nil
    local closestDifference = nil
    
    for _, possible in next, answers do
        local delta = math.abs(answer - possible)
        
        if closestDifference == nil or delta < closestDifference then
            closestAnswer = possible
            closestDifference = delta
        end
    end
    
    if not closestAnswer then
        return
    end
    
    choiceRemote:FireServer(tostring(closestAnswer))
end

